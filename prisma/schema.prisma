generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model categories {
  id       Int        @id
  name     String     @db.VarChar(255)
  products products[]
}

model products {
  id              String      @id @db.VarChar(50)
  product_code    String?     @db.VarChar(50)
  category_id     Int?
  name            String      @db.VarChar(255)
  brand           String?     @db.VarChar(100)
  image_url       String?
  original_price  Decimal?    @db.Decimal(12, 2)
  sale_price      Decimal?    @db.Decimal(12, 2)
  rating_vote     Decimal?    @db.Decimal(3, 1)
  quantity_sold   String?     @db.VarChar(50)
  color           String?     @db.VarChar(50)
  warranty_policy String?
  promotion       String?
  spec_product    Json?
  url             String?
  created_at      DateTime?   @default(now()) @db.Timestamp(6)
  categories      categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([spec_product], map: "idx_products_spec_product", type: Gin)
}
