generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model brands {
  id       Int        @id @default(autoincrement())
  name     String     @unique @db.VarChar(255)
  products products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id            Int        @id @default(autoincrement())
  category_code String     @unique @db.VarChar(50)
  name          String     @db.VarChar(255)
  products      products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id             BigInt                 @id @default(autoincrement())
  model_code     String?                @db.VarChar(100)
  sku            String?                @unique @db.VarChar(100)
  product_id_web String?                @db.VarChar(100)
  name           String
  category_id    Int?
  brand_id       Int?
  description    String?
  original_price Decimal?               @db.Decimal(15, 2)
  sale_price     Decimal?               @db.Decimal(15, 2)
  gift_promotion String?
  rating         Decimal?               @default(0) @db.Decimal(2, 1)
  review_count   Int?                   @default(0)
  stock          Int?                   @default(0)
  thumbnail      String?
  specifications Json
  embedding      Unsupported("vector")?
  created_at     DateTime?              @default(now()) @db.Timestamp(6)
  updated_at     DateTime?              @default(now()) @db.Timestamp(6)
  brands         brands?                @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories     categories?            @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([embedding], map: "idx_products_embedding")
  @@index([specifications], map: "idx_products_specs", type: Gin)
}
